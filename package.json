{
    "name": "happiness",
    "author": "Sanil Chawla <hi@sanil.co> (https://sanil.co)",
    "license": "Apache-2.0",
    "version": "0.2.0",
    "scripts": {
        "dev": "next dev -p ${HP_DEV_PORT:-3000}",
        "dev:db": "concurrently --kill-others 'bun dev' 'bun db:gui' -n 'next,db-gui' -c 'bgCyan,bgMagenta'",
        "build": "next build",
        "start": "next start",
        "lint": "biome check .",
        "lint:fix": "biome check --write .",
        "format": "biome format --write .",
        "typecheck": "tsc --noEmit",
        "db:push": "drizzle-kit push:mysql --config ./drizzle.config.ts",
        "db:gui": "drizzle-kit studio --port 3100",
        "test:e2e": "dotenv -e .env.test -- playwright test",
        "test:e2e:ui": "dotenv -e .env.test -- playwright test --ui",
        "test:e2e:docker:up": "docker compose -f docker-compose.test.yml up -d --wait",
        "test:e2e:docker:down": "docker compose -f docker-compose.test.yml down -v"
    },
    "dependencies": {
        "@changesets/changelog-github": "^0.4.8",
        "@changesets/cli": "^2.26.2",
        "@commitlint/cli": "^17.7.1",
        "@commitlint/config-conventional": "^17.7.0",
        "@fortawesome/fontawesome-svg-core": "^6.4.2",
        "@fortawesome/free-regular-svg-icons": "^6.4.2",
        "@fortawesome/free-solid-svg-icons": "^6.4.2",
        "@fortawesome/react-fontawesome": "^0.2.0",
        "@planetscale/database": "^1.11.0",
        "@scalar/nextjs-api-reference": "^0.10.6",
        "@ssh/csstypes": "^1.1.0",
        "@stripe/react-stripe-js": "^5.6.1",
        "@stripe/stripe-js": "^8.11.0",
        "@svgr/webpack": "^8.1.0",
        "@types/node": "^22.0.0",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@types/spark-md5": "^3.0.2",
        "@types/yargs": "^17.0.24",
        "@upstash/redis": "^1.37.0",
        "@vercel/analytics": "^1.0.2",
        "@vercel/speed-insights": "^1.2.0",
        "autoprefixer": "^10.4.15",
        "better-auth": "^1.5.6",
        "clsx": "^2.0.0",
        "concurrently": "^8.2.1",
        "dayjs": "^1.11.9",
        "dotenv": "^16.3.1",
        "drizzle-kit": "0.19.13",
        "drizzle-orm": "0.28.6",
        "drizzle-zod": "0.5.1",
        "email-validator": "^2.0.4",
        "jspdf": "^4.2.1",
        "mysql2": "^3.6.0",
        "nanoid": "^4.0.2",
        "next": "^16.2.2",
        "nodemailer": "^8.0.4",
        "openapi3-ts": "^4.1.2",
        "paris": "^0.18.1",
        "postcss": "^8.4.29",
        "pte": "^0.4.9",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "react-markdown": "^10.1.0",
        "sass": "^1.66.1",
        "spark-md5": "^3.0.2",
        "stripe": "^13.4.0",
        "tailwindcss": "3.3.3",
        "typescript": "^5.9.3",
        "wawoff2": "^2.0.1",
        "yargs": "^17.7.2",
        "zod": "^3.22.2",
        "zod-validation-error": "^1.5.0"
    },
    "overrides": {},
    "devDependencies": {
        "@biomejs/biome": "^2.4.10",
